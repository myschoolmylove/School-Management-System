rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "ernestvdavid@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super')
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "ernestvdavid@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'school'))
      );
    }

    function isSchoolAdmin(schoolId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'school' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId;
    }

    function isFinanceAdmin(schoolId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'school' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'finance' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'accountant') &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId;
    }

    function isRegistrar(schoolId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'school' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'registrar') &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId;
    }

    function isTeacher(schoolId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId;
    }

    function isParent(schoolId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'parent' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId;
    }

    function isStudent(schoolId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId;
    }

    function isSchoolActive(schoolId) {
      return isSuperAdmin() || (exists(/databases/$(database)/documents/schools/$(schoolId)) && 
                                get(/databases/$(database)/documents/schools/$(schoolId)).data.status == 'Active');
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Public Admissions
    match /public_admissions/{admissionId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Public Applications
    match /public_applications/{applicationId} {
      allow read: if isSuperAdmin();
      allow create: if true; // Allow public to apply
      allow update, delete: if isSuperAdmin();
    }

    // Public Results
    match /public_results/{resultId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin() || 
                   (isAuthenticated() && 
                    exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                    (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'school' ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') && 
                    resource.data.schoolId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId);
      allow create: if isSuperAdmin() || 
                     (isAuthenticated() && 
                      exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'school' ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') && 
                      request.resource.data.schoolId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId &&
                      request.resource.data.role != 'super');
      allow update: if isOwner(userId) || isSuperAdmin() ||
                             (isAuthenticated() && 
                              exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                              (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'school' ||
                               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') && 
                              resource.data.schoolId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId &&
                              request.resource.data.schoolId == resource.data.schoolId &&
                              request.resource.data.role != 'super');
      allow delete: if isOwner(userId) || isSuperAdmin() ||
                             (isAuthenticated() && 
                              exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                              (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'school' ||
                               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') && 
                              resource.data.schoolId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId &&
                              resource.data.role != 'super');
    }

    // Schools collection
    match /schools/{schoolId} {
      allow read: if true; // Allow public read for login page
      allow write: if isSuperAdmin() || isSchoolAdmin(schoolId);

      // Students subcollection
      match /students/{studentId} {
        allow read: if isSchoolActive(schoolId) && (isSuperAdmin() || isRegistrar(schoolId) || isTeacher(schoolId) || 
                     (isParent(schoolId) && request.auth.uid == resource.data.parentUid) ||
                     (isStudent(schoolId) && resource.data.rollNo == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username));
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isRegistrar(schoolId));
      }

      // Homework subcollection
      match /homework/{homeworkId} {
        allow read: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId) || isTeacher(schoolId) || isParent(schoolId) || isStudent(schoolId));
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId) || isTeacher(schoolId));
      }

      // Events subcollection
      match /events/{eventId} {
        allow read: if isSchoolActive(schoolId); // Public events only if school is active
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId));
      }

      // Gallery subcollection
      match /gallery/{galleryId} {
        allow read: if isSchoolActive(schoolId); // Public gallery only if school is active
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId));
      }

      // Timetables subcollection
      match /timetables/{timetableId} {
        allow read: if isSchoolActive(schoolId);
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId) || isTeacher(schoolId));
      }

      // Date Sheets subcollection
      match /datesheets/{datesheetId} {
        allow read: if isSchoolActive(schoolId);
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId) || isTeacher(schoolId));
      }

      // Results subcollection
      match /results/{resultId} {
        allow read: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId) || isTeacher(schoolId) || 
                     (isParent(schoolId) && request.auth.uid == resource.data.parentUid) ||
                     (isStudent(schoolId) && resource.data.rollNo == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username));
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId) || isTeacher(schoolId));
      }

      // Attendance subcollection
      match /attendance/{attendanceId} {
        allow read: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId) || isTeacher(schoolId) || 
                     (isParent(schoolId) && request.auth.uid == resource.data.parentUid) ||
                     (isStudent(schoolId) && resource.data.rollNo == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username));
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId) || isTeacher(schoolId));
      }

      // Vouchers subcollection
      match /vouchers/{voucherId} {
        allow read: if isSchoolActive(schoolId) && (isSuperAdmin() || isFinanceAdmin(schoolId) || 
                     (isParent(schoolId) && request.auth.uid == resource.data.parentUid) ||
                     (isStudent(schoolId) && resource.data.rollNo == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username));
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isFinanceAdmin(schoolId));
      }

      // Teachers subcollection
      match /teachers/{teacherId} {
        allow read: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId) || isTeacher(schoolId));
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId));
      }

      // Inventory subcollection
      match /inventory/{itemId} {
        allow read: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId));
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId));
      }

      // Finance subcollection
      match /finance/{transactionId} {
        allow read: if isSchoolActive(schoolId) && (isSuperAdmin() || isFinanceAdmin(schoolId));
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isFinanceAdmin(schoolId));
      }

      // Admissions subcollection
      match /admissions/{admissionId} {
        allow read: if isSchoolActive(schoolId) && (isSuperAdmin() || isRegistrar(schoolId));
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isRegistrar(schoolId));
      }

      // Notices subcollection
      match /notices/{noticeId} {
        allow read: if isSchoolActive(schoolId);
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId));
      }

      // Config subcollection
      match /config/{configId} {
        allow read: if isSchoolActive(schoolId);
        allow write: if isSchoolActive(schoolId) && (isSuperAdmin() || isSchoolAdmin(schoolId));
      }
    }
    
    // Audit logs
    match /audit_logs/{logId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && 
                   resource.data.schoolId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId);
      allow create: if isAuthenticated();
    }

    // System Config
    match /system_config/{id} {
      allow read: if true; // Allow public read for maintenance mode check
      allow write: if isSuperAdmin();
    }

    // Public Results
    match /public_results/{resultId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}
