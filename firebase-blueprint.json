{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system (Super Admin, School Admin, Teacher, Parent).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super", "school", "teacher", "parent"] },
        "schoolId": { "type": "string", "description": "ID of the school the user belongs to" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "name"]
    },
    "School": {
      "title": "School",
      "description": "Represents a school registered in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "contact": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro", "premium"] },
        "status": { "type": "string", "enum": ["Active", "Suspended", "Pending"] },
        "expiry": { "type": "string", "description": "ISO date string or 'N/A'" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "plan", "status"]
    },
    "Student": {
      "title": "Student",
      "description": "Represents a student in a school.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "name": { "type": "string" },
        "rollNo": { "type": "string" },
        "classId": { "type": "string" },
        "sectionId": { "type": "string" },
        "parentUid": { "type": "string", "description": "UID of the parent user" }
      },
      "required": ["id", "schoolId", "name", "rollNo", "classId", "sectionId"]
    },
    "Homework": {
      "title": "Homework",
      "description": "Represents a homework or assignment task.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "classId": { "type": "string" },
        "sectionId": { "type": "string" },
        "subject": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "schoolId", "classId", "sectionId", "subject", "title", "dueDate"]
    },
    "Event": {
      "title": "Event",
      "description": "Represents a school event or notice.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["holiday", "event", "exam", "other"] }
      },
      "required": ["id", "schoolId", "title", "date", "type"]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "Represents an image in the school gallery.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["id", "schoolId", "imageUrl"]
    },
    "PublicAdmission": {
      "title": "Public Admission Notice",
      "description": "Represents a public admission notice shown on the admissions page.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["School", "College", "University"] },
        "location": { "type": "string" },
        "desc": { "type": "string" },
        "deadline": { "type": "string", "format": "date" }
      },
      "required": ["title", "deadline", "type", "location"]
    },
    "PublicApplication": {
      "title": "Public Admission Application",
      "description": "Represents an application submitted through the public admissions page.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "admissionId": { "type": "string" },
        "admissionTitle": { "type": "string" },
        "studentName": { "type": "string" },
        "parentName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "class": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Received", "Contacted", "Closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentName", "phone", "email"]
    },
    "PublicResult": {
      "title": "Public Board Result",
      "description": "Represents a board result searchable by roll number.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "rollNo": { "type": "string" },
        "studentName": { "type": "string" },
        "fatherName": { "type": "string" },
        "board": { "type": "string" },
        "marks": { "type": "number" },
        "totalMarks": { "type": "number" },
        "grade": { "type": "string" },
        "year": { "type": "string" },
        "session": { "type": "string" },
        "status": { "type": "string", "enum": ["Pass", "Fail"] }
      },
      "required": ["rollNo", "studentName", "marks", "totalMarks", "board", "year", "session"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Represents a student's daily attendance record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Present", "Absent", "Late", "Leave"] },
        "checkIn": { "type": "string" }
      },
      "required": ["studentId", "date", "status"]
    },
    "Fee": {
      "title": "Fee",
      "description": "Represents a student's fee record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "month": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Paid", "Unpaid", "Pending"] },
        "date": { "type": "string", "format": "date" },
        "voucherId": { "type": "string" }
      },
      "required": ["studentId", "month", "amount", "status"]
    },
    "Result": {
      "title": "Internal Result",
      "description": "Represents a student's internal school result.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "term": { "type": "string" },
        "subject": { "type": "string" },
        "marks": { "type": "number" },
        "total": { "type": "number" },
        "grade": { "type": "string" },
        "remarks": { "type": "string" }
      },
      "required": ["studentId", "term", "subject", "marks", "total"]
    },
    "Timetable": {
      "title": "Timetable",
      "description": "Represents a class timetable entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "classId": { "type": "string" },
        "day": { "type": "string" },
        "subject": { "type": "string" },
        "teacher": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" }
      },
      "required": ["classId", "day", "subject", "startTime", "endTime"]
    },
    "DateSheet": {
      "title": "Date Sheet",
      "description": "Represents an examination schedule entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "classId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "subject": { "type": "string" },
        "time": { "type": "string" },
        "venue": { "type": "string" }
      },
      "required": ["classId", "date", "subject", "time"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/schools/{schoolId}": { "schema": "School", "description": "School details" },
    "/schools/{schoolId}/students/{studentId}": { "schema": "Student", "description": "Students in a school" },
    "/schools/{schoolId}/homework/{homeworkId}": { "schema": "Homework", "description": "Homework tasks" },
    "/schools/{schoolId}/events/{eventId}": { "schema": "Event", "description": "School events" },
    "/schools/{schoolId}/gallery/{galleryId}": { "schema": "GalleryItem", "description": "School gallery items" },
    "/schools/{schoolId}/attendance/{attendanceId}": { "schema": "Attendance", "description": "Attendance records" },
    "/schools/{schoolId}/fees/{feeId}": { "schema": "Fee", "description": "Fee records" },
    "/schools/{schoolId}/results/{resultId}": { "schema": "Result", "description": "Internal results" },
    "/schools/{schoolId}/timetables/{timetableId}": { "schema": "Timetable", "description": "Class timetables" },
    "/schools/{schoolId}/datesheets/{datesheetId}": { "schema": "DateSheet", "description": "Exam date sheets" },
    "/public_admissions/{admissionId}": { "schema": "PublicAdmission", "description": "Public admission notices" },
    "/public_applications/{applicationId}": { "schema": "PublicApplication", "description": "Applications from public admissions page" },
    "/public_results/{resultId}": { "schema": "PublicResult", "description": "Public board results" }
  }
}
